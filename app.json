{
  "expo": {
    "name": "Pusha",
    "slug": "pusha",
    "version": "0.0.3",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "scheme": "pusha",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pushahq.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-android-foreground.png",
        "backgroundColor": "#142952"
      },
      "package": "com.pushahq.app",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "cover",
          "backgroundColor": "#142952",
          "imageWidth": 200
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/InstrumentSan-Medium.ttf",
            "./assets/fonts/InstrumentSan-Regular.ttf",
            "./assets/fonts/InstrumentSan-SemiBold.ttf",
            "./assets/fonts/InstrumentSan-Bold.ttf",
            "./assets/fonts/dahlia-regular.otf",
            "./assets/fonts/dahlia-medium.otf",
            "./assets/fonts/dahlia-bold.otf",
            "./assets/fonts/icomoon.ttf"
          ]
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Pusha to use Face ID to authtenticate sensitive actions."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Pusha needs permission to access your product photos which are used in your product listings."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Pusha to access your photos.",
          "savePhotosPermission": "Allow Pusha to save photos."
        }
      ],
      [
        "expo-build-properties",
        {
          "buildReactNativeFromSource": true,
          "useHermesV1": true
        }
      ],
      "expo-web-browser",
      "expo-image"
    ],
    "updates": {
      "url": "https://u.expo.dev/4a07fb65-9729-4b75-b1cf-12f622d1c3b2",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "enableBsdiffPatchSupport": true
    },
    "runtimeVersion": "0.0.1",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "ENV": {
        "BASE_URL": "https://pusha-beta-6ubbw.ondigitalocean.app",
        "DEV_BASE_URL": "https://pusha-beta-6ubbw.ondigitalocean.app",
        "CLOUDINARY_NAME": "delzblzt7"
      },
      "DASHBOARD_CHAT_SOCKET_URL": "wss://api-beta.pushahq.com/webchat",
      "router": {},
      "eas": {
        "projectId": "4a07fb65-9729-4b75-b1cf-12f622d1c3b2"
      }
    },
    "owner": "pushahq"
  }
}
